{
  "name": "@awalogo/figma-plugin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm validate:manifest && pnpm build:plugin-ui && pnpm build:controller && pnpm validate:plugin-build",
    "build:ui": "vite build",
    "build:plugin-ui": "vite build --config vite.plugin.config.ts",
    "build:controller": "vite build --config vite.main.config.ts",
    "dev": "vite --host 127.0.0.1",
    "validate:manifest": "node scripts/validate-manifest.mjs",
    "watch:ui": "vite build --config vite.plugin.config.ts --watch",
    "watch:controller": "vite build --config vite.main.config.ts --watch",
    "validate:plugin-build": "node scripts/validate-plugin-build.mjs",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@awalogo/core": "workspace:*",
    "@awalogo/institutions": "workspace:*",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^1.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@figma/plugin-typings": "^1.101.0",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  }
}
