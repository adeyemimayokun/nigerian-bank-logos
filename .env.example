# GitHub OAuth app used only to identify maintainers.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# A comma-separated, case-insensitive list of approved GitHub usernames.
ADMIN_GITHUB_LOGINS=

# Generate with: openssl rand -base64 48
ADMIN_SESSION_SECRET=

# Fine-grained token with Contents and Pull requests read/write access to this repo.
GITHUB_ADMIN_TOKEN=
GITHUB_REPOSITORY=adeyemimayokun/nigerian-bank-logos
GITHUB_DEFAULT_BRANCH=main

# Canonical deployed origin, without a trailing slash.
PUBLIC_SITE_URL=
